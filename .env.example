# Application Configuration
APP_NAME=Intelli-Credit Engine
APP_VERSION=0.1.0
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/intellicredit

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=intellicredit-documents

# OCR Configuration
TEXTRACT_ENABLED=True
OCR_CONFIDENCE_THRESHOLD=0.85

# Cross-Verification Thresholds
REVENUE_VARIANCE_THRESHOLD=10.0

# External API Keys
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
ECOURTS_API_KEY=your_ecourts_api_key_here
MCA_API_KEY=your_mca_api_key_here

# Processing Configuration
MAX_DOCUMENT_SIZE_MB=100
PROCESSING_TIMEOUT_MINUTES=30

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
